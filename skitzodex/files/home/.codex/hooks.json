{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/lib/skitzodex/gitignore-guard.sh",
            "statusMessage": "Checking gitignored paths"
          }
        ]
      }
    ]
  }
}
